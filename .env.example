# ============================================================
# Environment Configuration Template
# Copy to .env and fill in your API keys:  cp .env.example .env
# ============================================================

# ── LLM Configuration ───────────────────────────────────────
# At minimum, configure ONE provider with its API key and model.

# OpenAI
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_PROD_MODEL=gpt-4o
# OPENAI_DEV_MODEL=gpt-4o-mini

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google (Gemini)
# GOOGLE_API_KEY=your-key-here
# GEMINI_API_KEY=your-key-here

# DeepSeek
# DEEPSEEK_API_KEY=your-key-here

# Mistral
# MISTRAL_API_KEY=your-key-here

# Perplexity
# PERPLEXITY_API_KEY=pplx-your-key-here

# ── Default Model ───────────────────────────────────────────
# Fallback model used when no specific model is configured.
# DEFAULT_LLM_MODEL=gpt-4o

# ── Database ────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:pass@localhost:5432/dbname
# REDIS_URL=redis://localhost:6379/0

# ── Authentication ──────────────────────────────────────────
# JWT_SECRET_KEY=change-this-to-a-random-string-at-least-32-chars

# ── Application ─────────────────────────────────────────────
# APP_ENV=development
# DEBUG=true
# LOG_LEVEL=INFO

# ── Discord Webhook (for contact form) ──────────────────────
# Get from Discord Server Settings > Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# ── Next Auth (for WA Sender login - future) ────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=https://topaitoolrank.com

# ── Google Analytics (optional) ──────────────────────────────
# Update GA4 Measurement ID in app/layout.tsx
# GA_MEASUREMENT_ID=G-XXXXXXXXXX
